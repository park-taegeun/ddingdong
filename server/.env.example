# 띵동 서버 환경변수 템플릿 (실제 .env 는 .gitignore 대상, 절대 commit 금지)
# 카테고리 6.1: Device / Dashboard Bearer Token 분리

# ESP32 → 서버 인증 토큰 (firmware/include/secrets.h 와 동일값 사용)
DEVICE_TOKEN=replace-with-device-token

# React 대시보드 → 서버 인증 토큰 (dashboard/.env VITE_DASHBOARD_TOKEN 와 동일값 사용)
DASHBOARD_TOKEN=replace-with-dashboard-token

# SQLite DB 경로 (미설정 시 server/ddingdong.db). *.db 는 .gitignore 대상
# DATABASE_URL=sqlite:///ddingdong.db
